---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";

/**
 * Generates full-path slugs from the file's id.
 *
 * Examples:
 *   "projects/health/full spectrum therapy lamp/index.md"
 *     → slug: "health/full-spectrum-therapy-lamp"
 *
 *   "projects/manufacturing/3d-printing/auto tuner/anomalies/warping.md"
 *     → slug: "manufacturing/3d-printing/auto-tuner/anomalies/warping"
 *
 *   "projects/manufacturing/3d-printing/auto tuner/index.md"
 *     → slug: "manufacturing/3d-printing/auto-tuner"
 */
function idToSlug(id: string): string {
  return id
    .replace(/^projects\//, "")   // strip "projects/" prefix
    .replace(/\/index\.md$/, "")  // strip trailing /index.md
    .replace(/\.md$/, "")         // strip .md extension
    .replace(/\s+/g, "-")         // spaces to hyphens
    .toLowerCase();
}

/**
 * Determines if this entry is a project root (index.md with category)
 * vs. a subpage (anomaly, research note, etc.)
 */
function isProjectRoot(entry: any): boolean {
  return entry.id.endsWith("/index.md") && !!entry.data.category;
}

/**
 * Finds the parent project for a subpage by walking up the path.
 */
function findParent(entry: any, allEntries: any[]): any | null {
  const parts = entry.id.split("/");
  // Walk up directories looking for an index.md
  for (let i = parts.length - 2; i >= 1; i--) {
    const parentId = parts.slice(0, i + 1).join("/") + "/index.md";
    const parent = allEntries.find((e) => e.id === parentId);
    if (parent) return parent;
  }
  return null;
}

export async function getStaticPaths() {
  const allProjects = await getCollection("projects");

  return allProjects.map((project) => {
    const slug = idToSlug(project.id);
    const parent = isProjectRoot(project) ? null : findParent(project, allProjects);

    return {
      params: { slug },
      props: {
        project,
        parentTitle: parent?.data.title ?? null,
        parentSlug: parent ? idToSlug(parent.id) : null,
        isRoot: isProjectRoot(project),
      },
    };
  });
}

const { project, parentTitle, parentSlug, isRoot } = Astro.props;
const { Content } = await render(project);

// Breadcrumb: Home > [parent project] > current page
const breadcrumbs = [{ label: "Home", href: "/" }];
if (parentTitle && parentSlug) {
  breadcrumbs.push({
    label: parentTitle,
    href: `/projects/${parentSlug}`,
  });
}
breadcrumbs.push({ label: project.data.title, href: "" });
---

<BaseLayout title={`${project.data.title} — Eurisco Labs`} description={project.data.description}>
  <main class="max-w-3xl mx-auto px-6 py-16 sm:py-24">
    {/* Breadcrumb navigation */}
    <nav class="text-sm text-muted mb-8 flex items-center gap-1.5 flex-wrap">
      {breadcrumbs.map((crumb, i) => (
        <>
          {i > 0 && <span class="text-gray-300">/</span>}
          {crumb.href ? (
            <a href={crumb.href} class="hover:text-blue transition-colors no-underline">
              {crumb.label}
            </a>
          ) : (
            <span class="text-navy font-medium">{crumb.label}</span>
          )}
        </>
      ))}
    </nav>

    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-4">
      <h1 class="text-2xl sm:text-3xl font-bold text-navy">{project.data.title}</h1>
      {project.data.status && (
        <span class="text-xs font-medium text-blue bg-blue/10 px-3 py-1 rounded-full w-fit">
          {project.data.status}
        </span>
      )}
    </div>

    <p class="text-muted leading-relaxed mb-6">{project.data.description}</p>

    {/* Tags (only for project roots) */}
    {isRoot && project.data.tags?.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-8">
        {project.data.category && (
          <span class="text-xs font-medium text-navy bg-navy/10 px-2 py-0.5 rounded">
            {project.data.category}
          </span>
        )}
        {project.data.tags.map((tag: string) => (
          <span class="text-xs text-muted border border-gray-200 px-2 py-0.5 rounded">{tag}</span>
        ))}
      </div>
    )}

    {/* Severity badge for anomaly/subpages */}
    {project.data.severity && (
      <div class="flex flex-wrap gap-2 mb-8">
        <span class={`text-xs font-medium px-2 py-0.5 rounded ${
          project.data.severity === "Critical" ? "text-red-700 bg-red-100" :
          project.data.severity === "High" ? "text-orange-700 bg-orange-100" :
          project.data.severity === "Medium" ? "text-yellow-700 bg-yellow-100" :
          "text-gray-700 bg-gray-100"
        }`}>
          {project.data.severity} severity
        </span>
        {project.data.category && (
          <span class="text-xs text-muted border border-gray-200 px-2 py-0.5 rounded">
            {project.data.category}
          </span>
        )}
      </div>
    )}

    <div class="border-t border-gray-200 pt-8 prose prose-slate max-w-none
      [&_h1]:text-xl [&_h1]:font-semibold [&_h1]:text-navy [&_h1]:mt-8 [&_h1]:mb-4
      [&_h2]:text-lg [&_h2]:font-semibold [&_h2]:text-navy [&_h2]:mt-6 [&_h2]:mb-3
      [&_h3]:text-base [&_h3]:font-semibold [&_h3]:text-navy [&_h3]:mt-4 [&_h3]:mb-2
      [&_p]:text-sm [&_p]:text-muted [&_p]:leading-relaxed [&_p]:mb-4
      [&_ul]:text-sm [&_ul]:text-muted [&_ul]:mb-4 [&_ul]:list-disc [&_ul]:pl-5
      [&_li]:mb-1
      [&_a]:text-blue [&_a]:underline
      [&_code]:text-sm [&_code]:bg-gray-100 [&_code]:px-1 [&_code]:rounded
      [&_table]:text-sm [&_table]:w-full [&_table]:mb-4
      [&_th]:text-left [&_th]:text-navy [&_th]:font-medium [&_th]:pb-2 [&_th]:border-b [&_th]:border-gray-200
      [&_td]:py-1.5 [&_td]:text-muted [&_td]:border-b [&_td]:border-gray-100">
      <Content />
    </div>
  </main>
</BaseLayout>
