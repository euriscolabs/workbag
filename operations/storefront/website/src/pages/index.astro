---
import BaseLayout from "../layouts/BaseLayout.astro";
import DirectoryListing from "../components/DirectoryListing.astro";
import { getCollection } from "astro:content";
import { buildContentTree } from "../lib/content-tree";

const title = "Eurisco Labs";
const tagline =
  "We design, build, and ship products at the intersection of software, hardware, and engineering — documented openly.";

const allEntries = await getCollection("content");
const tree = buildContentTree(allEntries);

const values = [
  {
    title: "Build openly",
    description:
      "Every project is documented from first sketch to final product — process, mistakes, and all.",
  },
  {
    title: "Research first",
    description:
      "We start with the science. Open lab notebooks, preprints, and accessible explanations.",
  },
  {
    title: "Made to last",
    description:
      "Functional, durable, repairable. No planned obsolescence, no dark patterns.",
  },
];
---

<BaseLayout title={title} description={tagline}>
  <!-- Hero -->
  <header
    class="max-w-4xl mx-auto px-6 flex flex-col items-center pt-20 pb-16 sm:pt-28 sm:pb-20 text-center"
  >
    <img
      src="/wordmark.svg"
      alt="Eurisco Labs"
      class="w-80 sm:w-96 max-w-full h-auto"
    />
    <p class="mt-8 text-lg sm:text-xl text-muted max-w-2xl leading-relaxed">
      {tagline}
    </p>
  </header>
  <main class="max-w-4xl mx-auto px-6">
    <!-- About -->
    <section class="py-12 sm:py-16 border-t border-gray-200">
      <h2 class="text-sm font-medium text-muted uppercase tracking-wider mb-8">
        What we believe
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 sm:gap-12">
        {
          values.map((v) => (
            <div>
              <h3 class="text-base font-semibold text-navy mb-2">{v.title}</h3>
              <p class="text-sm text-muted leading-relaxed">{v.description}</p>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Content tree -->
    <section class="py-12 sm:py-16 border-t border-gray-200">
      <h2 class="text-sm font-medium text-muted uppercase tracking-wider mb-8">
        What we're working on
      </h2>
      <DirectoryListing nodes={tree} />
    </section>
  </main>
</BaseLayout>
