---
import BaseLayout from "../layouts/BaseLayout.astro";
import DirectoryListing from "../components/DirectoryListing.astro";
import { getCollection, render } from "astro:content";
import { buildContentTree, flattenTree, idToSlug } from "../lib/content-tree";
import type { ContentNode } from "../lib/content-tree";

export async function getStaticPaths() {
  const allEntries = await getCollection("content");
  const tree = buildContentTree(allEntries);
  const allNodes = flattenTree(tree);

  return allNodes.map((node) => ({
    params: { slug: node.slug || undefined },
    props: { node },
  }));
}

const { node } = Astro.props as { node: ContentNode };
const { entry, type, children } = node;

// Render markdown content if a real entry exists
let Content: any = null;
if (entry) {
  const rendered = await render(entry);
  Content = rendered.Content;
}

// Build breadcrumbs from path segments
function titleFromSegment(segment: string): string {
  return segment
    .replace(/[-_]/g, " ")
    .replace(/\b\w/g, (c) => c.toUpperCase());
}

const breadcrumbs: { label: string; href: string }[] = [
  { label: "Home", href: "/" },
];
const pathParts = node.path.split("/");
for (let i = 0; i < pathParts.length - 1; i++) {
  const ancestorSlug = idToSlug(pathParts.slice(0, i + 1).join("/"));
  breadcrumbs.push({
    label: titleFromSegment(pathParts[i]),
    href: `/${ancestorSlug}`,
  });
}
breadcrumbs.push({ label: node.title, href: "" });

function badgeColor(level: string): string {
  switch (level) {
    case "Critical":
      return "text-red-700 bg-red-100";
    case "High":
      return "text-orange-700 bg-orange-100";
    case "Medium":
      return "text-yellow-700 bg-yellow-100";
    default:
      return "text-gray-700 bg-gray-100";
  }
}
---

<BaseLayout
  title={`${node.title} — Eurisco Labs`}
  description={node.description}
>
  <main class="max-w-3xl mx-auto px-6 py-16 sm:py-24">
    {/* Breadcrumb navigation */}
    <nav class="text-sm text-muted mb-8 flex items-center gap-1.5 flex-wrap">
      {
        breadcrumbs.map((crumb, i) => (
          <>
            {i > 0 && <span class="text-gray-300">/</span>}
            {crumb.href ? (
              <a
                href={crumb.href}
                class="hover:text-blue transition-colors no-underline"
              >
                {crumb.label}
              </a>
            ) : (
              <span class="text-navy font-medium">{crumb.label}</span>
            )}
          </>
        ))
      }
    </nav>

    {/* Hub rendering — title + description + content + children listing */}
    {
      type === "hub" && (
        <>
          <h1 class="text-2xl sm:text-3xl font-bold text-navy mb-4">
            {node.title}
          </h1>
          {node.description && (
            <p class="text-muted leading-relaxed mb-6">{node.description}</p>
          )}
        </>
      )
    }

    {/* Project rendering — status badge + tags */}
    {
      type === "project" && (
        <>
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-4">
            <h1 class="text-2xl sm:text-3xl font-bold text-navy">
              {node.title}
            </h1>
            {node.status && (
              <span class="text-xs font-medium text-blue bg-blue/10 px-3 py-1 rounded-full w-fit">
                {node.status}
              </span>
            )}
          </div>
          <p class="text-muted leading-relaxed mb-6">{node.description}</p>
          {entry?.data.tags?.length > 0 && (
            <div class="flex flex-wrap gap-2 mb-8">
              {entry.data.category && (
                <span class="text-xs font-medium text-navy bg-navy/10 px-2 py-0.5 rounded">
                  {entry.data.category}
                </span>
              )}
              {entry.data.tags.map((tag: string) => (
                <span class="text-xs text-muted border border-gray-200 px-2 py-0.5 rounded">
                  {tag}
                </span>
              ))}
            </div>
          )}
        </>
      )
    }

    {/* Article rendering — severity/priority badge */}
    {
      type === "article" && (
        <>
          <h1 class="text-2xl sm:text-3xl font-bold text-navy mb-4">
            {node.title}
          </h1>
          {node.description && (
            <p class="text-muted leading-relaxed mb-4">{node.description}</p>
          )}
          <div class="flex flex-wrap gap-2 mb-8">
            {entry?.data.severity && (
              <span
                class={`text-xs font-medium px-2 py-0.5 rounded ${badgeColor(entry.data.severity)}`}
              >
                {entry.data.severity} severity
              </span>
            )}
            {entry?.data.priority && (
              <span
                class={`text-xs font-medium px-2 py-0.5 rounded ${badgeColor(entry.data.priority)}`}
              >
                {entry.data.priority} priority
              </span>
            )}
            {entry?.data.category && (
              <span class="text-xs text-muted border border-gray-200 px-2 py-0.5 rounded">
                {entry.data.category}
              </span>
            )}
          </div>
        </>
      )
    }

    {/* Markdown content */}
    {
      Content && (
        <div
          class="border-t border-gray-200 pt-8 prose prose-slate max-w-none
      [&_h1]:text-xl [&_h1]:font-semibold [&_h1]:text-navy [&_h1]:mt-8 [&_h1]:mb-4
      [&_h2]:text-lg [&_h2]:font-semibold [&_h2]:text-navy [&_h2]:mt-6 [&_h2]:mb-3
      [&_h3]:text-base [&_h3]:font-semibold [&_h3]:text-navy [&_h3]:mt-4 [&_h3]:mb-2
      [&_p]:text-sm [&_p]:text-muted [&_p]:leading-relaxed [&_p]:mb-4
      [&_ul]:text-sm [&_ul]:text-muted [&_ul]:mb-4 [&_ul]:list-disc [&_ul]:pl-5
      [&_li]:mb-1
      [&_a]:text-blue [&_a]:underline
      [&_code]:text-sm [&_code]:bg-gray-100 [&_code]:px-1 [&_code]:rounded
      [&_table]:text-sm [&_table]:w-full [&_table]:mb-4
      [&_th]:text-left [&_th]:text-navy [&_th]:font-medium [&_th]:pb-2 [&_th]:border-b [&_th]:border-gray-200
      [&_td]:py-1.5 [&_td]:text-muted [&_td]:border-b [&_td]:border-gray-100"
        >
          <Content />
        </div>
      )
    }

    {/* Children listing for hubs */}
    {
      children.length > 0 && (
        <div class={Content ? "mt-8 pt-8 border-t border-gray-200" : ""}>
          {type === "hub" && !Content && (
            <h2 class="text-lg font-semibold text-navy mb-4">Contents</h2>
          )}
          <DirectoryListing nodes={children} />
        </div>
      )
    }
  </main>
</BaseLayout>
