---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => {
    const folder = project.id.split("/").at(-1) ?? project.id;
    const slug = folder.replace(/\s+/g, "-").toLowerCase();
    return { params: { slug }, props: { project } };
  });
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<BaseLayout title={`${project.data.title} — Eurisco Labs`} description={project.data.description}>
  <main class="max-w-3xl mx-auto px-6 py-16 sm:py-24">
    <a href="/" class="text-sm text-muted hover:text-blue transition-colors no-underline mb-8 inline-block">&larr; Back to home</a>

    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-4">
      <h1 class="text-2xl sm:text-3xl font-bold text-navy">{project.data.title}</h1>
      <span class="text-xs font-medium text-blue bg-blue/10 px-3 py-1 rounded-full w-fit">
        {project.data.status}
      </span>
    </div>

    <p class="text-muted leading-relaxed mb-6">{project.data.description}</p>

    <div class="flex flex-wrap gap-2 mb-8">
      <span class="text-xs font-medium text-navy bg-navy/10 px-2 py-0.5 rounded">{project.data.category}</span>
      {project.data.tags.map((tag: string) => (
        <span class="text-xs text-muted border border-gray-200 px-2 py-0.5 rounded">{tag}</span>
      ))}
    </div>

    <div class="border-t border-gray-200 pt-8 prose prose-slate max-w-none
      [&_h1]:text-xl [&_h1]:font-semibold [&_h1]:text-navy [&_h1]:mt-8 [&_h1]:mb-4
      [&_h2]:text-lg [&_h2]:font-semibold [&_h2]:text-navy [&_h2]:mt-6 [&_h2]:mb-3
      [&_h3]:text-base [&_h3]:font-semibold [&_h3]:text-navy [&_h3]:mt-4 [&_h3]:mb-2
      [&_p]:text-sm [&_p]:text-muted [&_p]:leading-relaxed [&_p]:mb-4
      [&_ul]:text-sm [&_ul]:text-muted [&_ul]:mb-4 [&_ul]:list-disc [&_ul]:pl-5
      [&_li]:mb-1
      [&_a]:text-blue [&_a]:underline
      [&_code]:text-sm [&_code]:bg-gray-100 [&_code]:px-1 [&_code]:rounded">
      <Content />
    </div>
  </main>
</BaseLayout>
